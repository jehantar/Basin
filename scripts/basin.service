[Unit]
Description=Basin data aggregator
After=network-online.target docker.service
Wants=network-online.target
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
User=basin
WorkingDirectory=/opt/basin
EnvironmentFile=/etc/basin/secrets
ExecStart=/usr/bin/op run --env-file=/opt/basin/.env -- /usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
Restart=on-failure
RestartSec=10s
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
