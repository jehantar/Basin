# Basin — copy to .env and fill in op:// references
# Start with: op run --env-file=.env -- docker compose up -d

BASIN_PG_PASSWORD="op://Basin/Postgres/password"

# Teller (download from teller.io dashboard)
TELLER_ACCESS_TOKEN="op://Basin/Teller/access_token"

# Telegram (reuse reservation bot credentials)
TELEGRAM_BOT_TOKEN="op://Basin/Telegram/bot_token"
TELEGRAM_CHAT_ID="op://Basin/Telegram/chat_id"

# Nasdaq Data Link (SHARADAR equity prices)
NASDAQ_DATA_LINK_API_KEY="op://Basin/Nasdaq data link/credential"

# HealthKit webhook authentication (optional but recommended)
HEALTHKIT_WEBHOOK_KEY="op://Basin/HealthKit/webhook_key"

# Strava API (elevation, GPS, activity data)
STRAVA_CLIENT_ID="your_client_id"
STRAVA_CLIENT_SECRET="op://Basin/Strava/client_secret"
STRAVA_REDIRECT_URI="http://100.125.126.42:8075/strava/callback"

# Intervals.icu (training load via Strava)
INTERVALS_ICU_API_KEY="op://Basin/intervals.icu API key/credential"
INTERVALS_ICU_ATHLETE_ID="i553742"

# Optional: externally published webhook port
WEBHOOK_BIND="8075"
