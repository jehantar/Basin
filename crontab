# Basin collector schedule
# Each job sources /etc/basin.env because cron does not inherit Docker env vars.
# Logs go to /var/log/basin/ inside the collector container.

# Hevy — check drop folder daily at 6:00 AM UTC
0 6 * * * set -a; . /etc/basin.env; set +a; cd /app && python -m collectors.hevy >> /var/log/basin/hevy.log 2>&1

# HealthKit XML — check import folder daily at 6:05 AM UTC
5 6 * * * set -a; . /etc/basin.env; set +a; cd /app && python -m collectors.healthkit >> /var/log/basin/healthkit.log 2>&1

# Teller — daily at 7:00 AM UTC
0 7 * * * set -a; . /etc/basin.env; set +a; cd /app && python -m collectors.teller >> /var/log/basin/teller.log 2>&1

# Nasdaq / SHARADAR — daily at 1:30 AM UTC (~9:30 PM ET; shifts with DST)
30 1 * * * set -a; . /etc/basin.env; set +a; cd /app && python -m collectors.nasdaq >> /var/log/basin/nasdaq.log 2>&1

# Intervals.icu — daily at 6:10 AM UTC (training load, pace/HR curves)
10 6 * * * set -a; . /etc/basin.env; set +a; cd /app && python -m collectors.intervals_icu >> /var/log/basin/intervals_icu.log 2>&1

# Strava — daily at 6:15 AM UTC (activity elevation, GPS, HR)
15 6 * * * set -a; . /etc/basin.env; set +a; cd /app && python -m collectors.strava >> /var/log/basin/strava.log 2>&1

# Daily Postgres backup at 2:00 AM UTC
0 2 * * * set -a; . /etc/basin.env; set +a; /app/scripts/backup.sh >> /var/log/basin/backup.log 2>&1

